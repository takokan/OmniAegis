# SentinelAgent environment template
# Copy this file to `.env` and replace placeholder values.

REDIS_URL=rediss://default:YOUR_UPSTASH_TOKEN@YOUR_UPSTASH_HOST:6379
DATABASE_URL=postgresql://postgres:YOUR_SUPABASE_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

NEO4J_URI=neo4j+s://YOUR_NEO4J_HOST
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=YOUR_NEO4J_PASSWORD

QDRANT_URL=https://YOUR-QDRANT-CLUSTER.cloud.qdrant.io:6333
QDRANT_API_KEY=YOUR_QDRANT_API_KEY

GRAFANA_PROMETHEUS_URL=https://YOUR_GRAFANA_INSTANCE/api/prom
GRAFANA_API_KEY=YOUR_GRAFANA_API_KEY

PINATA_API_KEY=YOUR_PINATA_API_KEY
WEB3_PROVIDER_URL=https://YOUR_CHAIN_PROVIDER
