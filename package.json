{
  "name": "omniaegis-workspace",
  "private": true,
  "version": "1.0.0",
  "description": "OmniAegis - AI-driven sentinel system with blockchain decision audit trails",
  "scripts": {
    "dev": "npm --prefix frontend run dev",
    "build": "npm --prefix frontend run build",
    "preview": "npm --prefix frontend run preview",
    "contracts:compile": "hardhat compile",
    "contracts:test": "hardhat test",
    "contracts:deploy": "hardhat run scripts/deploy.ts",
    "contracts:deploy:local": "hardhat run scripts/setup-local.ts --network localhost",
    "contracts:deploy:mumbai": "hardhat run scripts/deploy.ts --network mumbai",
    "contracts:deploy:polygon": "hardhat run scripts/deploy.ts --network polygon",
    "contracts:verify": "hardhat etherscan-verify",
    "contracts:coverage": "hardhat coverage",
    "backend:dev": "cd decision_layer && python -m uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "backend:install": "cd decision_layer && pip install -r requirements.txt",
    "start": "npm run backend:dev & npm run dev",
    "setup": "npm install && npm install --prefix frontend && npm run backend:install"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1",
    "pinata": "^2.5.5"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.2",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.0",
    "@nomiclabs/hardhat-ethers": "^2.2.3",
    "@openzeppelin/hardhat-upgrades": "^2.1.0",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.11",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.10.6",
    "chai": "^4.3.10",
    "dotenv": "^16.3.1",
    "ethers": "^6.13.2",
    "hardhat": "^2.21.0",
    "hardhat-gas-reporter": "^1.0.10",
    "solidity-coverage": "^0.8.8",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^5.3.3"
  }
}
